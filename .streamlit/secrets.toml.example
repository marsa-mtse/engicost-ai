# ─────────────────────────────────────────────────────────────
# EngiCost AI — Streamlit Cloud Secrets Template
# Copy real values into Streamlit Dashboard → Settings → Secrets
# ─────────────────────────────────────────────────────────────

# App Security
SECRET_KEY   = "change-me-to-a-long-random-string"

# Database (use Neon.tech free tier for production)
DATABASE_URL = "sqlite:///engicost.db"

# ─── AI Providers ──────────────────────────────────────────────
GEMINI_API_KEY = "AIza..."
GROQ_API_KEY   = "gsk_..."
OPENAI_API_KEY = "sk-..."

# ─── Paymob Egypt Payment Gateway ──────────────────────────────
# Get from: https://accept.paymob.com → Settings → Account Info
PAYMOB_API_KEY       = "eyJhbGci..."   # Your Paymob API Key (JWT)
PAYMOB_HMAC_SECRET   = "your-hmac-secret"
PAYMOB_CARD_INTG_ID  = "5586603"       # Card Integration ID
PAYMOB_FAWRY_INTG_ID = ""              # Fawry Integration ID (optional)
PAYMOB_IFRAME_ID     = ""              # Iframe ID from Paymob dashboard

